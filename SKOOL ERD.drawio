        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nhide circle\nskinparam linetype ortho\nskinparam classAttributeIconSize 0\n\n&#39;========================\n&#39; USERS\n&#39;========================\nentity profiles {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  full_name : text\n  email : text\n  password_hash : text\n  avatar_url : text\n  bio : text\n  created_at : timestamptz\n}\n\n&#39;========================\n&#39; COMMUNITY (GROUP)\n&#39;========================\nentity communities {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  owner_id : uuid &lt;&lt;FK&gt;&gt;\n  name : text\n  slug : text\n  description : text\n  cover_url : text\n  visibility : text  &#39;public|private\n  created_at : timestamptz\n}\n\nentity community_memberships {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  community_id : uuid &lt;&lt;FK&gt;&gt;\n  user_id : uuid &lt;&lt;FK&gt;&gt;\n  role : text        &#39;owner|admin|moderator|member\n  status : text      &#39;active|invited|banned|left\n  joined_at : timestamptz\n}\n\nentity invites {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  community_id : uuid &lt;&lt;FK&gt;&gt;\n  invited_email : text\n  invited_by : uuid &lt;&lt;FK&gt;&gt;\n  token : text\n  status : text      &#39;pending|accepted|expired\n  created_at : timestamptz\n  expires_at : timestamptz\n}\n\n&#39;========================\n&#39; POSTS (COMMUNITY FEED)\n&#39;========================\nentity posts {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  community_id : uuid &lt;&lt;FK&gt;&gt;\n  author_id : uuid &lt;&lt;FK&gt;&gt;\n  title : text\n  content : text\n  type : text        &#39;post|announcement|question\n  is_pinned : boolean\n  created_at : timestamptz\n}\n\nentity comments {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  post_id : uuid &lt;&lt;FK&gt;&gt;\n  author_id : uuid &lt;&lt;FK&gt;&gt;\n  parent_comment_id : uuid &lt;&lt;FK&gt;&gt;\n  content : text\n  created_at : timestamptz\n}\n\nentity reactions {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  target_type : text   &#39;post|comment\n  target_id : uuid\n  user_id : uuid &lt;&lt;FK&gt;&gt;\n  emoji : text\n  created_at : timestamptz\n}\n\n&#39;========================\n&#39; COURSES (CLASSROOM)\n&#39;========================\nentity courses {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  community_id : uuid &lt;&lt;FK&gt;&gt;\n  title : text\n  description : text\n  cover_url : text\n  status : text        &#39;draft|published\n  created_at : timestamptz\n}\n\nentity course_modules {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  course_id : uuid &lt;&lt;FK&gt;&gt;\n  title : text\n  sort_order : int\n}\n\nentity lessons {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  module_id : uuid &lt;&lt;FK&gt;&gt;\n  title : text\n  content : text\n  video_url : text\n  attachments_json : jsonb\n  sort_order : int\n}\n\nentity lesson_progress {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  lesson_id : uuid &lt;&lt;FK&gt;&gt;\n  user_id : uuid &lt;&lt;FK&gt;&gt;\n  status : text        &#39;not_started|in_progress|completed\n  completed_at : timestamptz\n}\n\n&#39;========================\n&#39; CALENDAR (EVENTS)\n&#39;========================\nentity events {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  community_id : uuid &lt;&lt;FK&gt;&gt;\n  created_by : uuid &lt;&lt;FK&gt;&gt;\n  title : text\n  description : text\n  start_at : timestamptz\n  end_at : timestamptz\n  meeting_url : text\n  created_at : timestamptz\n}\n\nentity event_attendance {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  event_id : uuid &lt;&lt;FK&gt;&gt;\n  user_id : uuid &lt;&lt;FK&gt;&gt;\n  status : text        &#39;going|maybe|not_going\n  responded_at : timestamptz\n}\n\n&#39;========================\n&#39; GAMIFICATION (POINTS/LEVELS)\n&#39;========================\nentity points_ledger {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  community_id : uuid &lt;&lt;FK&gt;&gt;\n  user_id : uuid &lt;&lt;FK&gt;&gt;\n  source_type : text   &#39;post|comment|lesson|event|manual\n  source_id : uuid\n  points : int\n  created_at : timestamptz\n}\n\nentity community_levels {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  community_id : uuid &lt;&lt;FK&gt;&gt;\n  level_number : int\n  required_points : int\n  title : text\n  unlock_description : text\n}\n\n&#39;========================\n&#39; PAYMENTS (MEMBERSHIP)\n&#39;========================\nentity plans {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  community_id : uuid &lt;&lt;FK&gt;&gt;\n  name : text\n  price_cents : int\n  currency : text\n  interval : text     &#39;month|year|one_time\n  is_active : boolean\n}\n\nentity subscriptions {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  plan_id : uuid &lt;&lt;FK&gt;&gt;\n  user_id : uuid &lt;&lt;FK&gt;&gt;\n  status : text        &#39;active|past_due|canceled|trialing\n  started_at : timestamptz\n  current_period_end : timestamptz\n  canceled_at : timestamptz\n}\n\nentity payments {\n  +id : uuid &lt;&lt;PK&gt;&gt;\n  --\n  subscription_id : uuid &lt;&lt;FK&gt;&gt;\n  provider : text      &#39;stripe|flouci|cash|other\n  provider_ref : text\n  amount_cents : int\n  currency : text\n  status : text        &#39;succeeded|failed|pending|refunded\n  created_at : timestamptz\n}\n\n&#39;========================\n&#39; RELATIONSHIPS\n&#39;========================\nprofiles ||--o{ communities : owns\ncommunities ||--o{ community_memberships\nprofiles ||--o{ community_memberships\n\ncommunities ||--o{ invites\nprofiles ||--o{ invites : invited_by\n\ncommunities ||--o{ posts\nprofiles ||--o{ posts : author\n\nposts ||--o{ comments\nprofiles ||--o{ comments : author\ncomments ||--o{ comments : replies\n\nprofiles ||--o{ reactions\nposts ||--o{ reactions\ncomments ||--o{ reactions\n\ncommunities ||--o{ courses\ncourses ||--o{ course_modules\ncourse_modules ||--o{ lessons\nlessons ||--o{ lesson_progress\nprofiles ||--o{ lesson_progress\n\ncommunities ||--o{ events\nevents ||--o{ event_attendance\nprofiles ||--o{ event_attendance\n\ncommunities ||--o{ points_ledger\nprofiles ||--o{ points_ledger\n\ncommunities ||--o{ community_levels\n\ncommunities ||--o{ plans\nplans ||--o{ subscriptions\nprofiles ||--o{ subscriptions\nsubscriptions ||--o{ payments\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="SzFSs_nqLRHFY6t8aBlb-1">
